  for (n1=0; n1 < DPbeads; n1++){
    for(d=0; d<DIMS; d++)
      fforce[n1*DIMS+d] = 0.0;
  }

  /* calculate drag force */
  /* calculate fluid velocity at the monomer coords. */
  n0 = 0;

#pragma omp parallel for num_threads(NTHREAD)
  for(n1=n0; n1< totalbeads; n1++) {
    double fric, mon_mass;
    int ni, d, x[DIMS]; 
    double vel[DIMS];

    if(n1 < nbeads_sph) {
      mon_mass = mass_sph;
      fric = fric_sph;
    }
    else if(n1 < DPbeads) {
      mon_mass = mass_poly;
      fric = fric_poly;
    }
    else {
      mon_mass = mass_cyl;
      fric = fric_cyl;
    }

    if(n1 < DPbeads) {
      ni = n1-n0;
      for(d=0; d<DIMS; d++)
	x[d] = mon[n1].pos[d];
      
      fluid_vel(n1, node_map, vel, x, velcs_df, mon);
      
      for(d=0; d<DIMS; d++) {
	mon[n1].fluid_vel[d]=vel[d];
	mon[n1].fricforce[d]=-fric*(mon[n1].vel[d]-vel[d]);
      }
    }
    else {
      for(d=0; d<DIMS; d++) {
	mon[n1].fluid_vel[d]=0.0;
	mon[n1].fricforce[d]=-fric*mon[n1].vel[d];
      }
    }
  }

  /* Generate the random force for DP, add_noise = 1 (Brownian particles), 2 (particle + fluid), 3 (fluid only) only for DP */
  if(add_noise >= 1 && add_noise !=3) 
    fluc_force(fforce, mon[0].stdev, DPbeads*DIMS, rngstream);
  
  /* propagation back to the fluid */
  n0 = 0; 
  
  //#pragma omp parallel for num_threads(NTHREAD)
  for(n1=n0; n1 < totalbeads; n1++) {
    int ni, nxy, d, i, j, k, q;
    int x[DIMS], x1[DIMS]; 
    double mon_mass, fric; 
    double force[DIMS]; 
    double x2[DIMS], dj_temp[DIMS], dmomentum[Num_Dir], temp[DIMS];
    
    if(n1 < nbeads_sph) {
      mon_mass = mass_sph;
      fric = fric_sph;
    }
    else if(n1 < DPbeads) {
      mon_mass = mass_poly;
      fric = fric_poly;
    }
    else {
      mon_mass = mass_cyl;
      fric = fric_cyl;
    }

    ni = n1-n0;
    for(d=0; d<DIMS; d++) {
      x[d] = (int)floor(mon[n1].pos[d]);               /* 0 <= floor(monomer position) <= max_size-1 */
      x2[d]=mon[n1].pos[d]-(double)x[d];   /* translate the coordinates of the monomer */
    }

  //    mon_proc = box(x[0],maxsize[0])/num_x;
  //    if(n_proc == mon_proc) {
    for(d=0; d<DIMS; d++) 
      force[d] = Rho_Fl*mon[n1].fricforce[d];

    if(n1 < DPbeads){
      for(d=0; d<DIMS; d++) {
        force[d] += fforce[ni*DIMS+d];
        mon[n1].f_fluc[d]=fforce[ni*DIMS+d];
        mon[n1].force[d] +=force[d];
      }
    }

    for(d=0; d<DIMS; d++) 
      dj_temp[d]=-force[d]*dt/(mon_mass*CS2*Rho_Fl);
    
    for(q=0; q<Num_Dir; q++) 
      dmomentum[q] = fac[q]*(c_x[q] * dj_temp[0] + c_y[q] * dj_temp[1] + c_z[q] * dj_temp[2]);
    
    for(k=0; k<=1; k++) {
      x1[2]=box(x[2]+k, maxsize[2])+1.0;
      
      if(k==0) 
	temp[2]=(1-x2[2]);
      else  
	temp[2]=x2[2];
      for(j=0; j<=1; j++) {
	x1[1]=box(x[1]+j, maxsize[1])+1.0;
	
	if(j==0) 
	  temp[1]=(1-x2[1]);
	else 
	  temp[1]=x2[1];
	
	for(i=0; i<=1; i++) { 
	  x1[0]=box((x[0]+i), maxsize[0])%num_x+1.0;
	  
	  if(i==0) 
	    temp[0]=1-x2[0];
	  else 
	    temp[0]=x2[0];
	  
	  nxy = x1[0]*(max_y+2)+x1[1];
	  for(q=0; q<DIMS; q++)
	    velcs_df[nxy][q][x1[2]] += dmomentum[q]*temp[0]*temp[1]*temp[2]; 
	} 
      } 
    } 
  }
  
  if(MD_tau == tau)
    MD_tau =1;
  else 
    MD_tau++;

  //  free(force);
  free(fforce);
}

void fluid_vel(int n1, int **node_map, double *vel, int x[DIMS], Float ***velcs_df, struct monomer *mon)
{
  extern int wall_flag;
  extern int max_x, max_y, max_z;
  extern int num_x;

  int i,j,k;
  int d,q,n,nxy;
  int x1[DIMS], maxsize[DIMS];
  double x2[DIMS];
  double vel_node[8][DIMS], rho_node[8];
  double temp[DIMS];
  double rho;
  
  maxsize[0]=max_x;
  maxsize[1]=max_y;
  maxsize[2]=max_z;

  for(i=0; i<8; i++)
    rho_node[i]=0.0;

  for(k=0; k<=1; k++) {
    x1[2] = box(x[2]+k, maxsize[2])+1;

    for(j=0; j<=1; j++) {
      x1[1] = box(x[1]+j, maxsize[1])+1;
	    
      for(i=0; i<=1; i++) {
	x1[0] = box((x[0]+i), maxsize[0])%num_x+1.0;
      
	nxy = x1[0]*(maxsize[1]+2)+(x1[1]);
	
	n=i*4+j*2+k;
	
	rho_node[n]=0.0;
	for(d=0; d<DIMS; d++)
	  vel_node[n][d]=0.0;
	
	/* calculate fluid velocity only if the lattice is not solid */
	if(node_map[nxy][x1[2]] != 1) {
	  for(q=0; q<Num_Dir; q++) { 
	    rho_node[n]   +=velcs_df[nxy][q][x1[2]];
	    vel_node[n][0]+=c_x[q]*velcs_df[nxy][q][x1[2]];
	    vel_node[n][1]+=c_y[q]*velcs_df[nxy][q][x1[2]];
	    vel_node[n][2]+=c_z[q]*velcs_df[nxy][q][x1[2]];
	  }
	  for(d=0; d<DIMS; d++)
	    vel_node[n][d] /= rho_node[n];
	}
      }
    }
  }

  /* wall boundary conditions */
  if(wall_flag >= 1) { 
    if(x[1] == 0) 
      for(i=0; i<=1; i++) 
	for(k=0; k<=1; k++) 
	  for(d=0; d<DIMS; d++)
	    vel_node[i*4+k][d]=-vel_node[i*4+2+k][d];
    
    if(x[1] == maxsize[1]-1) 
      for(i=0; i<=1; i++)
	for(k=0; k<=1; k++) 
	  for(d=0; d<DIMS; d++)
	    vel_node[i*4+2+k][d]=-vel_node[i*4+k][d];
  }

  if(wall_flag == 2) { 
    if(x[2] == 0) 
      for(i=0; i<=1; i++) 
	for(j=0; j<=1; j++) 
	  for(d=0; d<DIMS; d++)
	    vel_node[i*4+j*2][d]=-vel_node[i*4+j*2+1][d];
    
    if(x[2] == maxsize[2]-1) 
      for(i=0; i<=1; i++)
	for(j=0; j<=1; j++) 
	  for(d=0; d<DIMS; d++)
	    vel_node[i*4+j*2+1][d]=-vel_node[i*4+j*2][d];
  }
  
  /* Use trilinear interpolation to get the fluid velocity at the monomer position */
  for(d=0; d<DIMS; d++) {
    vel[d] = 0.0;
    x2[d]=mon[n1].pos[d]-(double)x[d];   /* translate the coordinates of the monomer */
  }

  for(k=0; k<=1; k++) {
    if(k==0) 
      temp[2]=1.0-x2[2];
    else 
      temp[2]=x2[2];
    
    for(j=0; j<=1; j++) {
      if(j==0) 
	temp[1]=1.0-x2[1];
      else 
	temp[1]=x2[1];
      
      for(i=0; i<=1; i++) { 
	if(i==0) 
	  temp[0]=1.0-x2[0];
	else 
	  temp[0]=x2[0];
	
	n=4*i+2*j+k;
	for(d=0; d<DIMS; d++) 
	  vel[d]+=vel_node[n][d]*temp[0]*temp[1]*temp[2];
      }
    }
  }

  //  for(d=0; d<DIMS; d++)    
  //    vel[ni][d] /= Rho_Fl;
}

void fluc_force(Float *force, double mon_stdev, int n, VSLStreamStatePtr rngstream)
{
  int errcode;

  /* Calculate the fluctuations */  
  errcode=vdRngGaussian( METHOD, rngstream, n, force, 0.0, mon_stdev);
  CheckVslError(errcode);

  //  printf("%le %le %le\n", f_fluc[0], f_fluc[1], f_fluc[2]);  
}


/* check for overlap between DP */
/* if a bead penetrate another DP, move it back outside, reflect boundary condition */
void Eval_faceforce(struct face *face, struct DP *DP, struct monomer *mon, struct DP_param *sphere_pm, double sigma, double sigma_LJ)
{
  const int stack = 6;
  extern int max_x, max_y, max_z;
  extern int wall_flag;
  int n1;
  int maxsize[DIMS];
  int flag = 0;
  double dt = sphere_pm->dt;
  double h_dt = dt/2.0;
  double h_dt2= h_dt*h_dt;
  double cutoff = 2.5*sigma;  // 2.5*sigma ?
  double cutoff2 = cutoff*cutoff;
  
  maxsize[0]=max_x;
  maxsize[1]=max_y;
  maxsize[2]=max_z;

  /* find the faces bead n1 is closest to */
//#pragma omp parallel for num_threads(NTHREAD) 
  for(n1=0; n1<sphere_pm->num_beads; n1++) {
    int n, n2, i, j, d, q, k, flag;
    int p1, p2, p3;
    int min_face[stack], min_bead[stack];
    double com[DIMS], com_tmp[DIMS], min_com[stack][DIMS], mincom_tmp[stack][DIMS];
    double d_com[DIMS]; 
    double q12[DIMS], q21[DIMS], q31[DIMS], q32[DIMS];
    double normal[stack][DIMS];
    double dr, dr1, dr2; 
    double mon_mass;
    double temp, h, h1, normalmag;
    double min_face_dr[stack];
    double min_dcom[stack][DIMS], min_d2com[stack][DIMS];

    for(q=0; q<stack; q++) {
      min_face[q] = -1;
      min_face_dr[q] =100;
      min_bead[q] = sphere_pm->num_beads+1;
    }

    for(n=1; n <= mon[n1].list[0]; n++) {
      n2 = mon[n1].list[n];

      if(n2 < sphere_pm->num_beads && (mon[n1].DP_id != mon[n2].DP_id)) {
	dr2=0.0;
	for(d=0; d<DIMS; d++) {
	  temp=mon[n1].pos_pbc[d] - mon[n2].pos_pbc[d];
	  if ((d==0 && wall_flag<3) || (d==2 && wall_flag<2) || (d==1 && wall_flag<1))
	    temp=n_image(temp, maxsize[d]);
	  dr2+=temp*temp;
	}
	
	if(dr2 > cutoff2) 
	  continue;
	else {
	  for(i=1; i<=mon[n2].face_id[0]; i++) {
	    flag = 0;
	    /* check if face has already been looped.  If so, skip */
	    for(k=0; k<stack; k++) 
	      if(mon[n2].face_id[i] == min_face[k]) {
		flag = 1;
		break;
	      }
	    if(flag == 1) continue;

	    for(d=0; d<DIMS; d++) {
	      com[d] = 0.0;
	      for(j=0; j<3; j++)
		com[d]+=mon[face[mon[n2].face_id[i]].vertices[j]].pos_pbc[d];
	      com[d]/=3.0;
	    }
	    
	    dr=0.0;
	    for(d=0; d<DIMS; d++) {
	      temp = mon[n1].pos_pbc[d] - com[d];
	      if ((d==0 && wall_flag<3) || (d==2 && wall_flag<2) || (d==1 && wall_flag<1))
		d_com[d]=n_image(temp, maxsize[d]);
	      else
		d_com[d]=temp;

	      dr += d_com[d]*d_com[d];
	    }

	    dr = sqrt(dr);

	    if(dr < min_face_dr[stack-1]) {
	      min_face_dr[stack-1] = dr;
	      min_bead[stack-1] = n2;
	      min_face[stack-1] = mon[n2].face_id[i];
	      
	      for(d=0; d<DIMS; d++) {
		min_com[stack-1][d]=com[d];
		mincom_tmp[stack-1][d]=com_tmp[d];
		min_dcom[stack-1][d]=d_com[d];
		
		temp = mon[n1].pos_tmp[d] - mincom_tmp[stack-1][d];
		if ((d==0 && wall_flag<3) || (d==2 && wall_flag<2) || (d==1 && wall_flag<1))
		  min_d2com[stack-1][d]=n_image(temp, maxsize[d]);
		else
		  min_d2com[stack-1][d]=temp;
	      }
	    }
	  
	    for(q=stack-2; q>=0; q--) {
	      if(dr < min_face_dr[q]) {
		min_face_dr[q+1] = min_face_dr[q];
		min_bead[q+1] = min_bead[q];
		min_face[q+1] = min_face[q];

		min_face_dr[q] = dr;
		min_bead[q] = n2;
		min_face[q] = mon[n2].face_id[i];

		for(d=0; d<DIMS; d++) {
		  min_com[q+1][d]=min_com[q][d];
		  mincom_tmp[q+1][d]= mincom_tmp[q][d];
		  min_dcom[q+1][d]=min_dcom[q][d];
		  min_d2com[q+1][d] = min_d2com[q][d];

		  min_com[q][d]=com[d];
		  mincom_tmp[q][d]=com_tmp[d];
		  min_dcom[q][d]=d_com[d];
	
		  temp = mon[n1].pos_tmp[d] - mincom_tmp[q][d];
		  if ((d==0 && wall_flag<3) || (d==2 && wall_flag<2) || (d==1 && wall_flag<1))
		    min_d2com[q][d]=n_image(temp, maxsize[d]);
		  else
		    min_d2com[q][d]=temp;
		}
	      }
	    }
	  }
	}
      }
    }
      
    /* if there are no nearby faces, continue to next bead */
    if(min_face_dr[0] == 100 || min_face[0] == -1) {
      flag = 0;
      continue;
    }

    for(q=0; q<stack; q++) {
      if(min_face[q] == -1) continue;

      /* loop over all vertices of closest face */
      p1 = face[min_face[q]].vertices[0];
      p2 = face[min_face[q]].vertices[1];
      p3 = face[min_face[q]].vertices[2];
      for (d=0 ; d<DIMS ; d++)
	q21[d] = mon[p2].pos_pbc[d] - mon[p1].pos_pbc[d];
      for (d=0 ; d<DIMS ; d++)
	q31[d] = mon[p3].pos_pbc[d] - mon[p1].pos_pbc[d];
      for (d=0 ; d<DIMS ; d++)
	q32[d] = mon[p3].pos_pbc[d] - mon[p2].pos_pbc[d];
      
      product(q21, q31, normal[q]);
    
      normalmag = 0.0;
      for(d=0; d<DIMS; d++)
	normalmag += normal[q][d]*normal[q][d];
      normalmag = sqrt(normalmag);
      
      for(d=0; d<DIMS; d++)
	normal[q][d] /= normalmag;
    
      /* determine the sign of the normal by comparing with distance of n1+normal from particle center */
      for(d=0; d<DIMS; d++) {
	com[d] = DP[mon[min_bead[q]].DP_id].com[d];
	com_tmp[d] = DP[mon[n1].DP_id].com[d];
      }
      
      /* determine whether the normal points in or out */
      dr1=0.0;
      double normaldotdr1 = 0.0;
      for(j=0; j<DIMS; j++) {
	temp = mon[n1].pos_pbc[j]-com[j];
	dr1+=temp*temp;
	normaldotdr1 += temp*normal[q][j];
      }
      dr1=sqrt(dr1);
      normaldotdr1 /= dr1;
      if(normaldotdr1 < 0.0) normaldotdr1 = -normaldotdr1;

      dr2=0.0;
      for(j=0; j<DIMS; j++) {
	temp = mon[n1].pos_pbc[j]-com[j]+dr1/2.0*normal[q][j];
	dr2+=temp*temp;
      }
      
      dr2 = sqrt(dr2);

      /* added condition to check for pinched concave surface */
      /* if cosine between the face normal and the COM-to-face vector < 0.5 */
      /* use the particle of n1 to determine the normal sign*/
      if(normaldotdr1 < 0.5) {
	for(j=0; j<DIMS; j++) {
	  temp = mon[n1].pos_pbc[j]-com_tmp[j];
	  dr1+=temp*temp;
	  normaldotdr1 += temp*normal[q][j];
	}
	dr1=sqrt(dr1);

	dr2=0.0;
	for(j=0; j<DIMS; j++) {
	  temp = mon[n1].pos_pbc[j]-com_tmp[j]+dr1/2.0*normal[q][j];
	  dr2+=temp*temp;
	}
      
	dr2 = sqrt(dr2);

	if(dr2 > dr1) 
	  for(d=0; d<DIMS; d++)
	    normal[q][d] = -1.0 * normal[q][d];
      }
      else {
	if(dr1 > dr2) 
	  for(d=0; d<DIMS; d++)
	    normal[q][d] = -1.0 * normal[q][d];
      }
	
      /* determine the normal distance of bead to face */
      h=normal[q][0]*min_dcom[q][0]+normal[q][1]*min_dcom[q][1]+normal[q][2]*min_dcom[q][2];
      h1=normal[q][0]*min_d2com[q][0]+normal[q][1]*min_d2com[q][1]+normal[q][2]*min_d2com[q][2];

      if(h < sigma_LJ) {
	if(EV_DEBUG == 1)
	  printf("faceEV n1 %d n2 %d (%le %le %le) face %d dr %lf h=%lf\n", n1, min_bead[q], mon[min_bead[q]].pos_pbc[0], mon[min_bead[q]].pos_pbc[1], mon[min_bead[q]].pos_pbc[2], min_face[q], sqrt(min_face_dr[q]), h);

	face_force(sigma_LJ, n1, p1, p2, p3, h, normal[q], sphere_pm, mon);
      }

      /* Reflect bead position across face */
      /*
	if(h <  -1.0e-9)  {
	flag = 1;
	mon_mass = Rho_Fl*sphere_pm->monmass;
	
	for(j=0; j<DIMS; j++) {
	mon[n1].pos_pbc[j] -= h*normal[j];
	mon[n1].pos[j]=box(mon[n1].pos_pbc[j], maxsize[j]);
	}
	}
      */
    }
  }
}


/*  Replaced by check_overlap between bead and neighboring DP in verlet_update */
/*  Adding repulsion between a bead and a nearby face */
void face_force(double sigma_LJ, int n1, int p1, int p2, int p3, double htemp, double *normal, struct DP_param *sphere_pm, struct monomer *mon)
{
  int i,j, d;
  double dt = sphere_pm->dt;
  double eps = sphere_pm->eps*sphere_pm->kT/sigma_LJ;
  double aterm, h, num1, num2, num3, det, sum;
  double pos[DIMS], force[DIMS];
  double p1x,p2x,p3x,p1y,p2y,p3y,p1z,p2z,p3z;

  if(htemp < 0) h = -htemp;
  else h = htemp;
  aterm = (sigma_LJ/h);
  aterm = aterm*aterm;
  aterm = aterm*aterm*aterm;

  /* Calculate the force distribution onto the neighbor face and apply face force */
  for(d=0; d<DIMS; d++) 
    pos[d] = mon[n1].pos[d]-h*normal[d];

  p1x = mon[p1].pos_pbc[0];   p2x = mon[p2].pos_pbc[0]; p3x = mon[p3].pos_pbc[0];
  p1y = mon[p1].pos_pbc[1];   p2y = mon[p2].pos_pbc[1]; p3y = mon[p3].pos_pbc[1];
  p1z = mon[p1].pos_pbc[2];   p2z = mon[p2].pos_pbc[2]; p3z = mon[p3].pos_pbc[2];
  
  det = p1x*(p2y*p3z-p3y*p2z)+p1y*(p3x*p2z-p2x*p3z)+p1z*(p2x*p3y-p3x*p2y);
  num1 = (pos[0]*(p2y*p3z-p3y*p2z)+pos[1]*(p2z*p3x-p3z*p2x)+pos[2]*(p3y*p2x-p2y*p3x))/det;
  num2 = (pos[0]*(p3y*p1z-p3z*p1y)+pos[1]*(p3z*p1x-p1z*p3x)+pos[2]*(p3x*p1y-p3y*p1x))/det;
  num3 = (pos[0]*(p1y*p2z-p1z*p2y)+pos[1]*(p1z*p2x-p1x*p2z)+pos[2]*(p1x*p2y-p2x*p1y))/det;

  if(num1 < 0.0 || num2 < 0.0 || num3 < 0.0) 
    return;

  if(num1 > 1.0 || num2 > 1.0 || num3 > 1.0) 
    return;
  
  sum = num1+num2+num3;
  num1 /= sum;
  num2 /= sum;
  num3 /= sum;

  if(EV_DEBUG == 1) {
    if(force[0] > 10 || force[0] < -10 || force[1] > 10 || force[1] < -10 || force[2] > 10 || force[2] < -10) {
      printf("faceEV h=%le (%le %le %le) force (%le %le %le)\n", h, normal[0], normal[1], normal[2], force[0], force[1], force[2]);
      printf("n1 %d (%le %le %le) \n p1 %d (%le %le %le) \n p2 %d (%le %le %le) \n p3 %d (%le %le %le)\n", n1, mon[n1].pos_pbc[0], mon[n1].pos_pbc[1], mon[n1].pos_pbc[2], p1, mon[p1].pos_pbc[0], mon[p1].pos_pbc[1], mon[p1].pos_pbc[2], p2, mon[p2].pos_pbc[0], mon[p2].pos_pbc[1], mon[p2].pos_pbc[2], p3, mon[p3].pos_pbc[0], mon[p3].pos_pbc[1], mon[p3].pos_pbc[2]);
      printf("det=%le num1=%le num2=%le num3=%le\n", det, num1, num2, num3);
    }
  }

  for(i=0; i<DIMS; i++) {
  //force[i]= -24.0*(eps*(2.0*(aterm*aterm)-aterm))/h * normal[i];
    force[i]= -100.0 * (sphere_pm->kT/sigma_LJ) * (sigma_LJ-htemp)*(sigma_LJ-htemp)/(sigma_LJ*sigma_LJ)* normal[i];

    //    force[i]= -24.0*(eps*(2.0*(aterm*aterm)-aterm)) * normal[i];
    mon[n1].force[i] -= force[i];
    mon[n1].evforce[i] -= force[i];
  }

  for (i=0; i<DIMS; i++) {
    mon[p1].force[i] += force[i]*num1;
    mon[p2].force[i] += force[i]*num2;
    mon[p3].force[i] += force[i]*num3;
    mon[p1].evforce[i] += force[i]*num1;
    mon[p2].evforce[i] += force[i]*num2;
    mon[p3].evforce[i] += force[i]*num3;
  }
  
  for(i=0; i<DIMS; i++) 
    for(j=0; j<DIMS; j++) {
      mon[n1].stress[i][j] += h*normal[i]* force[j] * sphere_pm->monmass;

      mon[p1].stress[i][j] -= h*normal[i]* force[j] * sphere_pm->monmass * num1;
      mon[p2].stress[i][j] -= h*normal[i]* force[j] * sphere_pm->monmass * num2;
      mon[p3].stress[i][j] -= h*normal[i]* force[j] * sphere_pm->monmass * num3;
    }
}
